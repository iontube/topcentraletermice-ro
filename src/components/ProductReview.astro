---
interface Props {
  name: string;
  slug: string;
  affiliate: string;
  specs: Record<string, string>;
  review: {
    paragrafe: string[];
    pentruCine: string;
    pro: string[];
    contra: string[];
    verdict: string;
  };
}
const { name, slug, affiliate, specs, review } = Astro.props;
const imgSrc = `/assets/images/products/${slug}.webp`;
const reviewId = 'recenzie-' + name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/,'');
---
<article class="rev" id={reviewId}>
  <div class="rev__header">
    <div class="rev__photo">
      <img src={imgSrc} alt={name} width="140" height="140" loading="lazy" />
    </div>
    <div class="rev__info">
      <h3>{name}</h3>
      <div class="rev__chips">
        {Object.entries(specs).map(([k, v]) => (
          <span class="rev__chip"><strong>{k}</strong>{v}</span>
        ))}
      </div>
    </div>
  </div>

  <div class="rev__columns">
    <div class="rev__main">
      {review.paragrafe.map(p => <p set:html={p} />)}
    </div>
    <aside class="rev__side">
      <div class="rev__target">
        <span class="rev__side-label">Recomandat pentru</span>
        <p>{review.pentruCine}</p>
      </div>
      <div class="rev__pros">
        <span class="rev__side-label">Avantaje</span>
        <ul>{review.pro.map(p => <li>{p}</li>)}</ul>
      </div>
      <div class="rev__cons">
        <span class="rev__side-label">Dezavantaje</span>
        <ul>{review.contra.map(c => <li>{c}</li>)}</ul>
      </div>
    </aside>
  </div>

  <div class="rev__verdict">
    <span class="rev__verdict-label">Verdict</span>
    <p>{review.verdict}</p>
  </div>

  <div class="rev__cta">
    <a href={`/out/${slug}/`} class="btn btn--cta btn--full" rel="nofollow sponsored noopener" target="_blank">Vezi pret si disponibilitate</a>
  </div>
</article>
