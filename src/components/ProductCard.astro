---
interface Props {
  name: string;
  slug: string;
  affiliate: string;
  specs: Record<string, string>;
  summary?: string;
  badge?: string;
  badgeType?: string;
}
const { name, slug, affiliate, specs, summary, badge, badgeType = 'top' } = Astro.props;
const imgSrc = `/assets/images/products/${slug}.webp`;
const reviewId = 'recenzie-' + name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/,'');
const specEntries = Object.entries(specs);
---
<article class="card">
  {badge && <span class={`card__flag card__flag--${badgeType}`}>{badge}</span>}
  <div class="card__visual">
    <img src={imgSrc} alt={name} width="280" height="200" loading="lazy" />
  </div>
  <div class="card__content">
    <h3 class="card__title">{name}</h3>
    <div class="card__tags">
      {specEntries.map(([k, v]) => (
        <span class="card__tag"><em>{k}</em>{v}</span>
      ))}
    </div>
    {summary && <p class="card__desc">{summary}</p>}
    <div class="card__actions">
      <a href={`/out/${slug}/`} class="card__buy" rel="nofollow sponsored noopener" target="_blank">Vezi Oferta</a>
      <a href={`#${reviewId}`} class="card__more">Recenzie &darr;</a>
    </div>
  </div>
</article>
